rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Your user ID for elite access
    function isEliteUser(userId) {
      return userId == 'YOUR_USER_ID_HERE';
    }

    // Basic rules for regular news app users
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
      
      match /preferences/{document=**} {
        allow read, write: if request.auth.uid == userId;
      }
      
      match /watchlist/{symbol} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // Strict rules for elite trading features
    match /users/{userId}/elite_trading/{document=**} {
      allow read, write: if isEliteUser(request.auth.uid);
    }

    match /users/{userId}/trading_signals/{document=**} {
      allow read, write: if isEliteUser(request.auth.uid);
    }

    match /users/{userId}/smart_money_data/{document=**} {
      allow read, write: if isEliteUser(request.auth.uid);
    }

    match /users/{userId}/foundation_analysis/{document=**} {
      allow read, write: if isEliteUser(request.auth.uid);
    }

    // Public news data accessible to all authenticated users
    match /news/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /catalysts/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /earnings/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
} 